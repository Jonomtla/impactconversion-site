# Resend — https://resend.com/api-keys
# Create an account, verify impactconversion.com as a sending domain, generate an API key
RESEND_API_KEY=re_your_key_here

# Email the contract submissions get sent to
RESEND_TO_EMAIL=jono@impactconversion.com

# The "from" address — must be on a domain verified in Resend
# Until impactconversion.com is verified, Resend allows onboarding@resend.dev for testing
RESEND_FROM_EMAIL=contracts@impactconversion.com
